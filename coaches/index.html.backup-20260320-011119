<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🐺 Wolf Pack Coaches Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #000;
            color: #fff;
            padding: 0;
        }

        .back-btn {
            position: fixed;
            top: 20px;
            left: 20px;
            background: #FDB80A;
            color: #000;
            padding: 12px 24px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 700;
            z-index: 1000;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 80px 20px 40px;
        }

        /* Header */
        .main-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .main-header h1 {
            font-size: 48px;
            color: #FDB80A;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .view-only-banner {
            background: #1a1a1a;
            border: 1px solid #FDB80A;
            padding: 12px 20px;
            text-align: center;
            font-size: 14px;
            color: #FDB80A;
            margin-bottom: 30px;
            border-radius: 6px;
        }

        /* Status Legend */
        .status-legend {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 50px;
            padding: 20px;
            background: #0a0a0a;
            border-radius: 8px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 600;
        }

        .legend-item.red { color: #dc2626; }
        .legend-item.yellow { color: #eab308; }
        .legend-item.green { color: #22c55e; }
        .legend-item.blue { color: #3b82f6; }

        /* Collapsible Section */
        .collapsible-section {
            margin-bottom: 30px;
            border: 2px solid #FDB80A;
            border-radius: 8px;
            overflow: hidden;
        }

        .section-header {
            background: #1a1a1a;
            padding: 20px 30px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
        }

        .section-header:hover {
            background: #222;
        }

        .section-header h2 {
            font-size: 24px;
            color: #FDB80A;
            font-weight: 700;
        }

        .section-arrow {
            font-size: 20px;
            color: #FDB80A;
            transition: transform 0.3s ease;
        }

        .collapsible-section.open .section-arrow {
            transform: rotate(90deg);
        }

        .section-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .collapsible-section.open .section-content {
            max-height: 5000px;
        }

        .section-inner {
            padding: 40px 30px;
        }

        /* Overview Metrics */
        .overview-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .overview-card {
            background: #000;
            border: 2px solid #FDB80A;
            border-radius: 8px;
            padding: 30px 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .overview-card h3 {
            font-size: 16px;
            color: #fff;
            margin-bottom: 20px;
            font-weight: 600;
        }

        .overview-card .target {
            font-size: 13px;
            color: #888;
        }

        .overview-circle {
            width: 120px;
            height: 120px;
            margin: 20px auto;
            position: relative;
        }

        .overview-circle svg {
            transform: rotate(-90deg);
        }

        .overview-circle circle {
            fill: none;
            stroke-width: 10;
        }

        .overview-value {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 28px;
            font-weight: 700;
            color: #fff;
        }

        /* Coach Card */
        .coach-card {
            background: #000;
            border-top: 3px solid #FDB80A;
            border-bottom: 3px solid #FDB80A;
            padding: 30px 0;
            margin-bottom: 30px;
        }

        .coach-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px 30px;
        }

        .coach-info h3 {
            font-size: 28px;
            color: #FDB80A;
            margin-bottom: 5px;
            font-weight: 700;
        }

        .coach-info .role {
            font-size: 12px;
            color: #888;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .status-badge {
            padding: 10px 20px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-badge.needs-focus { background: #dc2626; color: #fff; }
        .status-badge.on-track { background: #eab308; color: #000; }
        .status-badge.healthy { background: #22c55e; color: #000; }
        .status-badge.legendary { background: #3b82f6; color: #fff; }

        /* Metrics Grid */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            padding: 0 30px;
        }

        .metric-card {
            background: #000;
            border: 2px solid #FDB80A;
            border-radius: 8px;
            padding: 30px 15px;
            text-align: center;
            min-height: 220px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .progress-circle {
            width: 90px;
            height: 90px;
            margin: 0 auto 15px;
            position: relative;
        }

        .progress-circle svg {
            transform: rotate(-90deg);
        }

        .progress-circle circle {
            fill: none;
            stroke-width: 8;
        }

        .progress-bg { stroke: #1a1a1a; }

        .progress-fill {
            stroke-linecap: round;
            transition: stroke-dashoffset 0.8s ease;
        }

        .progress-fill.green { stroke: #22c55e; }
        .progress-fill.red { stroke: #dc2626; }
        .progress-fill.yellow { stroke: #eab308; }
        .progress-fill.blue { stroke: #3b82f6; }

        .progress-value {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 22px;
            font-weight: 700;
            color: #fff;
        }

        .metric-name {
            font-size: 13px;
            color: #fff;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .metric-target {
            font-size: 11px;
            color: #666;
        }

        @media (max-width: 1200px) {
            .overview-grid,
            .metrics-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }
    </style>
</head>
