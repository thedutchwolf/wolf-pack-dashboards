    <script>
        let currentWeek = '2026-W11';

        function updateKPI(exec, kpi) {
            const inputId = `${exec}-${kpi}-input`;
            const circleId = `${exec}-${kpi}-circle`;
            const valueId = `${exec}-${kpi}-value`;
            
            const inputElement = document.getElementById(inputId);
            const circleElement = document.getElementById(circleId);
            const valueElement = document.getElementById(valueId);
            
            if (!inputElement || !circleElement || !valueElement) {
                return;
            }
            
            const actual = parseFloat(inputElement.value) || 0;
            const target = parseFloat(inputElement.dataset.target) || 1;
            const percentage = (actual / target) * 100;
            
            // Special formatting for EOD (count display)
            if (kpi === 'eod') {
                valueElement.textContent = `${Math.round(actual)}/${target}`;
            } else {
                const displayPercentage = Math.min(Math.round(percentage), 150);
                valueElement.textContent = `${displayPercentage}%`;
            }
            
            circleElement.classList.remove('circle-excellent', 'circle-good', 'circle-warning', 'circle-needs-attention');
            
            if (percentage > 110) {
                circleElement.classList.add('circle-excellent');
            } else if (percentage >= 100) {
                circleElement.classList.add('circle-good');
            } else if (percentage >= 80) {
                circleElement.classList.add('circle-warning');
            } else {
                circleElement.classList.add('circle-needs-attention');
            }
            
            saveKPIData(exec, kpi, actual, target, percentage);
            updateMemberStatus(exec);
        }

        function saveKPIData(exec, kpi, actual, target, percentage) {
            try {
                const allWeeksData = JSON.parse(localStorage.getItem('wolfPackWeeksData') || '{}');
                if (!allWeeksData[currentWeek]) {
                    allWeeksData[currentWeek] = {};
                }
                if (!allWeeksData[currentWeek][exec]) allWeeksData[currentWeek][exec] = {};
                allWeeksData[currentWeek][exec][kpi] = {
                    actual: actual,
                    target: target,
                    percentage: percentage,
                    timestamp: Date.now()
                };
                localStorage.setItem('wolfPackWeeksData', JSON.stringify(allWeeksData));
                localStorage.setItem('wolfPackKPIs', JSON.stringify(allWeeksData[currentWeek]));
            } catch (error) {
                console.error('Error saving data:', error);
            }
        }

        function updateMemberStatus(exec) {
            const statusElement = document.getElementById(`${exec}-status`);
            if (statusElement) {
                const memberCard = statusElement.closest('.member-card');
                const circles = memberCard.querySelectorAll('.kpi-circle');
                let excellentCount = 0;
                let goodCount = 0;
                let totalCount = circles.length;
                
                circles.forEach(circle => {
                    if (circle.classList.contains('circle-excellent')) excellentCount++;
                    else if (circle.classList.contains('circle-good')) goodCount++;
                });
                
                if (excellentCount >= totalCount * 0.7) {
                    statusElement.textContent = '🔵 LEGENDARY';
                    statusElement.className = 'member-status status-excellent';
                } else if ((excellentCount + goodCount) >= totalCount * 0.5) {
                    statusElement.textContent = '🟢 CRUSHING IT';
                    statusElement.className = 'member-status status-good';
                } else {
                    statusElement.textContent = '🔴 NEEDS FOCUS';
                    statusElement.className = 'member-status status-needs-attention';
                }
            }
        }

        function changeWeek(direction) {
            const selector = document.getElementById('weekSelector');
            const currentIndex = selector.selectedIndex;
            const newIndex = currentIndex + direction;
            
            if (newIndex >= 0 && newIndex < selector.options.length) {
                selector.selectedIndex = newIndex;
                loadSelectedWeek();
            }
        }

        function loadSelectedWeek() {
            const selector = document.getElementById('weekSelector');
            currentWeek = selector.value;
            loadKPIData(currentWeek);
        }

        function loadKPIData(weekId) {
            try {
                const allWeeksData = JSON.parse(localStorage.getItem('wolfPackWeeksData') || '{}');
                const kpiData = allWeeksData[weekId] || {};
                
                // Clear all first
                const allInputs = document.querySelectorAll('.kpi-input');
                allInputs.forEach(input => input.value = '');
                
                const allCircles = document.querySelectorAll('.kpi-circle');
                allCircles.forEach(circle => {
                    circle.classList.remove('circle-excellent', 'circle-good', 'circle-warning', 'circle-needs-attention');
                    circle.classList.add('circle-needs-attention');
                    const valueElement = circle.querySelector('.circle-value');
                    if (valueElement) valueElement.textContent = '0%';
                });
                
                // Load data
                for (const [exec, kpis] of Object.entries(kpiData)) {
                    for (const [kpi, data] of Object.entries(kpis)) {
                        const inputElement = document.getElementById(`${exec}-${kpi}-input`);
                        const circleElement = document.getElementById(`${exec}-${kpi}-circle`);
                        const valueElement = document.getElementById(`${exec}-${kpi}-value`);
                        
                        if (inputElement && circleElement && valueElement) {
                            inputElement.value = data.actual;
                            
                            // Special formatting for EOD
                            if (kpi === 'eod') {
                                valueElement.textContent = `${Math.round(data.actual)}/${data.target}`;
                            } else {
                                valueElement.textContent = `${Math.round(data.percentage)}%`;
                            }
                            
                            circleElement.classList.remove('circle-excellent', 'circle-good', 'circle-warning', 'circle-needs-attention');
                            if (data.percentage > 110) {
                                circleElement.classList.add('circle-excellent');
                            } else if (data.percentage >= 100) {
                                circleElement.classList.add('circle-good');
                            } else if (data.percentage >= 80) {
                                circleElement.classList.add('circle-warning');
                            } else {
                                circleElement.classList.add('circle-needs-attention');
                            }
                        }
                    }
                    updateMemberStatus(exec);
                }
            } catch (error) {
                console.error('Error loading data:', error);
            }
        }

