<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🐺 Wolf Pack Executive Command Center</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0E0E0F;
            color: #E3E1DE;
            min-height: 100vh;
        }

        .header {
            background: linear-gradient(135deg, #0E0E0F 0%, #131313 100%);
            padding: 2rem;
            text-align: center;
            border-bottom: 2px solid #FDB80A;
        }

        .header h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .wolf-text {
            color: #FDB80A;
        }

        .week-controls {
            margin: 1rem 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
        }

        .week-btn {
            padding: 0.5rem 1rem;
            background: #A29A65;
            border: none;
            color: #0E0E0F;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
        }

        .week-btn:hover {
            background: #FDB80A;
        }

        select {
            padding: 0.5rem;
            background: #0E0E0F;
            color: #FDB80A;
            border: 1px solid #FDB80A;
            border-radius: 4px;
            font-weight: 600;
        }

        .member-card {
            background: linear-gradient(135deg, #131313 0%, #0E0E0F 100%);
            border-radius: 12px;
            padding: 2rem;
            border: 1px solid #A29A65;
            margin: 2rem;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);
        }

        .member-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            border-bottom: 1px solid #A29A65;
            padding-bottom: 1rem;
        }

        .member-info h3 {
            color: #FDB80A;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .member-role {
            color: #A29A65;
            font-size: 1rem;
        }

        .member-status {
            padding: 0.5rem 1rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .status-excellent { 
            color: #4A90E2; 
            background: rgba(74, 144, 226, 0.1);
            border: 1px solid #4A90E2;
        }

        .status-good { 
            color: #00d4aa; 
            background: rgba(0, 212, 170, 0.1);
            border: 1px solid #00d4aa;
        }

        .status-needs-attention { 
            color: #ff4444; 
            background: rgba(255, 68, 68, 0.1);
            border: 1px solid #ff4444;
        }

        .kpis-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .kpi-item {
            text-align: center;
            padding: 1rem;
        }

        .kpi-circle {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 3px solid #ff4444;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            transition: all 0.3s ease;
        }

        .circle-excellent {
            border-color: #4A90E2;
            box-shadow: 0 0 15px rgba(74, 144, 226, 0.3);
        }

        .circle-good {
            border-color: #00d4aa;
            box-shadow: 0 0 15px rgba(0, 212, 170, 0.3);
        }

        .circle-warning {
            border-color: #FDB80A;
            box-shadow: 0 0 15px rgba(253, 184, 10, 0.3);
        }

        .circle-needs-attention {
            border-color: #ff4444;
            box-shadow: 0 0 15px rgba(255, 68, 68, 0.3);
        }

        .circle-value {
            font-weight: 700;
            font-size: 1rem;
            color: white;
        }

        .kpi-name {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #E3E1DE;
        }

        .kpi-details {
            color: #A29A65;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .kpi-input-group {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
        }

        .kpi-input {
            padding: 0.5rem;
            background: #131313;
            border: 1px solid #A29A65;
            border-radius: 4px;
            color: #E3E1DE;
            width: 100px;
        }

        .update-btn {
            padding: 0.5rem 1rem;
            background: linear-gradient(45deg, #FDB80A, #E5A609);
            border: none;
            color: #0E0E0F;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
        }

        .update-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(253, 184, 10, 0.4);
        }

        .controls {
            text-align: center;
            margin: 2rem 0;
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .control-btn {
            padding: 0.8rem 1.5rem;
            background: #A29A65;
            border: none;
            color: #0E0E0F;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .control-btn:hover {
            background: #FDB80A;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(253, 184, 10, 0.4);
        }
    </style>
</head>
