        function exportData() {
            const data = localStorage.getItem('wolfPackWeeksData');
            if (data) {
                const blob = new Blob([data], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'wolfpack-kpi-data.json';
                a.click();
                URL.revokeObjectURL(url);
            }
        }

        function resetWeek() {
            if (confirm('Reset alle data voor deze week?')) {
                const allWeeksData = JSON.parse(localStorage.getItem('wolfPackWeeksData') || '{}');
                allWeeksData[currentWeek] = {};
                localStorage.setItem('wolfPackWeeksData', JSON.stringify(allWeeksData));
                localStorage.setItem('wolfPackKPIs', '{}');
                loadKPIData(currentWeek);
            }
        }

        // Initialize
        window.addEventListener('load', () => {
            loadKPIData(currentWeek);
        });
    </script>
